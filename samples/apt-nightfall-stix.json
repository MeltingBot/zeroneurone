      ]
    },
    {
      "type": "attack-pattern",
      "id": "attack-pattern--e5e5e5e5-f6f6-a7a7-b8b8-c9c9c9c9c9c9",
      "spec_version": "2.1",
      "created": "2026-01-15T10:00:00.000Z",
      "modified": "2026-01-15T10:00:00.000Z",
      "name": "Exfiltration Over Alternative Protocol - DNS-over-HTTPS",
      "description": "Exfiltration des données SCADA via requêtes DNS-over-HTTPS (DoH) vers un résolveur contrôlé par l'attaquant. Les données sont encodées en base32 dans les sous-domaines des requêtes TXT. Débit faible (environ 50 KB/h) mais quasi-indétectable par les solutions DPI classiques.",
