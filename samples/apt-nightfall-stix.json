    {
      "type": "malware",
      "id": "malware--11111111-2222-3333-4444-555555555555",
      "spec_version": "2.1",
      "created": "2026-01-20T10:00:00.000Z",
      "modified": "2026-03-01T10:00:00.000Z",
      "name": "NightLoader",
      "description": "Loader initial multi-stage utilisé pour la phase de compromission initiale. Stage 1 : PowerShell encodé exécuté par macro VBA. Stage 2 : shellcode injecté dans svchost.exe via process hollowing. Stage 3 : téléchargement et exécution en mémoire du payload final depuis un bucket S3 compromis. Polymorphique : chaque build génère un hash unique. Anti-sandbox : vérifie le nombre de CPU, la RAM, la présence de processus de virtualisation, et attend 15 minutes avant exécution.",
      "malware_types": ["loader", "downloader"],
      "is_family": true,
      "first_seen": "2023-08-01T00:00:00.000Z",
      "last_seen": "2026-02-15T00:00:00.000Z",
      "operating_system_refs": ["software--windows-10", "software--windows-11", "software--windows-server-2019"],
      "capabilities": [
        "persists-after-system-reboot",
        "anti-debugging",
        "anti-vm",
        "evades-av"
      ],
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-attack",
          "phase_name": "execution"
        }
      ]
    },
    {
      "type": "malware",
      "id": "malware--22222222-3333-4444-5555-666666666666",
      "spec_version": "2.1",
      "created": "2026-02-01T10:00:00.000Z",
      "modified": "2026-03-10T10:00:00.000Z",
      "name": "GhostPLC",
      "description": "Implant SCADA custom conçu pour les environnements Siemens S7 (protocole S7comm) et Schneider Modbus/TCP. Capable de lire/écrire des registres PLC, de modifier des setpoints de pression et de température, et d'intercepter les communications HMI-PLC pour masquer les modifications aux opérateurs (man-in-the-middle OT). Compilé en Golang avec support cross-platform. Communique via un canal C2 encapsulé dans des trames OPC-UA légitimes.",
      "malware_types": ["backdoor", "remote-access-trojan"],
      "is_family": true,
      "first_seen": "2024-03-01T00:00:00.000Z",
      "last_seen": "2026-02-28T00:00:00.000Z",
      "capabilities": [
        "communicates-with-c2",
        "captures-input-peripherals",
        "compromises-data-integrity"
      ],
      "architecture_execution_envs": ["x86-64", "arm"],
      "implementation_languages": ["Go"],
      "kill_chain_phases": [
        {
          "kill_chain_name": "mitre-ics-attack",
          "phase_name": "impair-process-control"
        }
      ]
    },
    {
      "type": "malware",
      "id": "malware--33333333-4444-5555-6666-777777777777",
      "spec_version": "2.1",
      "created": "2026-02-10T10:00:00.000Z",
      "modified": "2026-03-05T10:00:00.000Z",
      "name": "ValveDrop",
      "description": "Module de persistance déployé sur les engineering workstations du réseau OT. Se greffe sur le processus TIA Portal de Siemens via DLL sideloading (tiap_helper.dll). Intercepte les projets PLC ouverts par les ingénieurs et y injecte silencieusement des blocs de code ST (Structured Text) malveillants qui survivront au prochain déploiement sur automate. Mécanisme de persistence croisée : même si GhostPLC est détecté et supprimé, le code malveillant est redéployé au prochain cycle de maintenance.",
      "malware_types": ["backdoor"],
      "is_family": false,
      "first_seen": "2025-01-15T00:00:00.000Z",
      "capabilities": [
        "persists-after-system-reboot",
        "compromises-data-integrity",
        "compromises-data-availability"
      ],
      "implementation_languages": ["C++"],
      "kill_chain_phases": [
